    // Preset setup
    function setTimer(minutes, modeName) {
        clearInterval(timerInterval);
        timerIsRunning = false;
        
        timerTotalDuration = minutes * 60;
        timerTimeLeft = timerTotalDuration;
        timerModeName = modeName;
        
        updateTimerUI();
        
        document.getElementById('timer-current-mode').innerText = `${modeName} (${minutes}분)`;
        document.getElementById('play-icon').className = "fa-solid fa-play";
        document.getElementById('play-text').innerText = "타이머 가동";
        document.getElementById('timer-box').classList.remove('glow-active');
    }

    function updateTimerUI() {
        const mins = Math.floor(timerTimeLeft / 60);
        const secs = timerTimeLeft % 60;
        document.getElementById('timer-digits').innerText = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
        
        // Progress bar percentage
        const percentage = timerTimeLeft / timerTotalDuration;
        const dashoffset = 527 - (527 * percentage);
        document.getElementById('timer-progress-circle').setAttribute('stroke-dashoffset', dashoffset);
    }

    function resetTimerToDefault() {
        setTimer(25, '뽀모도로 집중 공부 세션');
    }

    // Handle play and pause action
    document.getElementById('timer-play-pause').addEventListener('click', () => {
        if (timerIsRunning) {
            // Pause
            clearInterval(timerInterval);
            timerIsRunning = false;
            document.getElementById('play-icon').className = "fa-solid fa-play";
            document.getElementById('play-text').innerText = "다시 시작";
            document.getElementById('timer-status').innerText = "일시 정지";
            document.getElementById('timer-box').classList.remove('glow-active');
        } else {
            // Start / Resume
            timerIsRunning = true;
            document.getElementById('play-icon').className = "fa-solid fa-pause";
            document.getElementById('play-text').innerText = "일시 정지";
            document.getElementById('timer-status').innerText = "진행 중 🔥";
            document.getElementById('timer-box').classList.add('glow-active');
            
            timerInterval = setInterval(() => {
                timerTimeLeft--;
                updateTimerUI();
                
                if (timerTimeLeft <= 0) {
                    clearInterval(timerInterval);
                    timerIsRunning = false;
                    document.getElementById('timer-status').innerText = "완료!";
                    document.getElementById('timer-box').classList.remove('glow-active');
                    playDingSFX();
                    
                    // Award points on successful timer completion
                    let pointsGained = 20; // default for timer
                    if (timerModeName.includes('운동')) {
                        pointsGained = 45;
                    } else if (timerModeName.includes('식사')) {
                        pointsGained = 15;
                    } else if (timerModeName.includes('뽀모도로') || timerModeName.includes('공부')) {
                        pointsGained = 25;
                    }
                    
                    userPoints += pointsGained;
                    saveSystemState();
                    updatePointsDisplay();
                    
                    showCustomAlert("집념의 완수! 🎉", `${timerModeName} 타이머를 끝까지 완수하여 +${pointsGained}p 보상을 지급했습니다!`, "fa-hourglass-end");
                    addSystemNotificationToChat(`[코칭 브리핑]: 사용자가 [${timerModeName}] 타이머를 성공적으로 끝마쳐 포인트 +${pointsGained}p 추가 획득 완료!`);
                    
                    resetTimerToDefault();
                }
            }, 1000);
        }
    });

    document.getElementById('timer-give-up').addEventListener('click', () => {
