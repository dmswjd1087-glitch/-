<script>
    // System State Variables with Persistent LocalStorage Support
    let userPoints = parseInt(localStorage.getItem('janus_points') || '0');
    let selectedDay = 1; // 1: Mon, 2: Tue, 3: Wed, 4: Thu, 5: Fri
    let currentModePlanB = false;
    let routineTasks = [];
    
    // Reward Shop Lists with Storage Backup
    let defaultRewards = [
        { id: 1, name: '굽네치킨 한 마리 🍗', points: 1000, emoji: '🍗' },
        { id: 2, name: '시원한 캔맥주 1캔 🍺', points: 250, emoji: '🍺' },
        { id: 3, name: '주말 꿀잠 프리패스 🛌', points: 500, emoji: '🛌' }
    ];
    let rewards = JSON.parse(localStorage.getItem('janus_rewards') || JSON.stringify(defaultRewards));

    // Timer Variables
    let timerInterval = null;
    let timerTimeLeft = 1500; // 25 min default
    let timerTotalDuration = 1500;
    let timerModeName = '뽀모도로 집중 공부 세션';
    let timerIsRunning = false;

    // Chat History List for Gemini Memory
    let chatHistory = [];

    // Synthesize Audio Feedback (SFX Ding)
    function playDingSFX() {
        try {
            const AudioContext = window.AudioContext || window.webkitAudioContext;
            if (!AudioContext) return;
            const ctx = new AudioContext();
            
            // Generate elegant 3-chord ding
            const playTone = (frequency, delay, duration) => {
                const osc = ctx.createOscillator();
                const gain = ctx.createGain();
                osc.type = 'sine';
                osc.frequency.value = frequency;
                
                gain.gain.setValueAtTime(0.3, delay);
                gain.gain.exponentialRampToValueAtTime(0.0001, delay + duration);
                
                osc.connect(gain);
                gain.connect(ctx.destination);
                
                osc.start(delay);
                osc.stop(delay + duration);
            };
            
            playTone(523.25, ctx.currentTime, 0.4); // C5
            playTone(659.25, ctx.currentTime + 0.1, 0.4); // E5
            playTone(783.99, ctx.currentTime + 0.2, 0.6); // G5
        } catch (e) {
            console.error("Audio Web Synth not available", e);
        }
    }

