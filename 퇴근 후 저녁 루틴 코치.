                { text: "집 도착! 식사 30분 타이머 시작 🍚", msg: "집 드디어 문 열고 들어왔어! 든든하게 먹을 식사 타이머 30분 키고 먹을게." },
                { text: "밥 다 먹었어! 자격증 공부하자 📚", msg: "저녁 배부르게 먹었어! 이제 책상 앞에 딱 25분간 앉을 준비 완료했어." },
                { text: "너무 지쳐서 힘들어... 살려줘 🛌", msg: "오늘 회사에서 일이 너무 많아서 힘드네... 루틴 가볍게 할 수 있는 플랜B 제안해줘!" }
            ];
        } else {
            // Workout Days
            replies = [
                { text: "퇴근길인데 바로 운동 동선 체크! 🏃‍♂️", msg: "지금 퇴근 가방 짊어지고 지하철 탔어! 바로 헬스장(또는 운동지) 직행할건데 힘 좀 불어넣어줘!" },
                { text: "운동 장소 세이프! 운동 가동 ⏱️", msg: "귀가 문 열지 않고 바로 센터 도착 성공했어! 이제부터 타이머 재고 45분 버닝 들어간다." },
                { text: "마시는 쉐이크 완료, 쾌감 샤워 🍼", msg: "운동 완벽 마무리에 쉐이크까지 원샷 완료했다! 몸이 너무 개운해." },
                { text: "다리 풀렸어... 오늘은 좀 가벼운 거 없을까?", msg: "어깨랑 다리가 너무 뻐근하고 부어올라... 빡세게 가기 힘든데 힐링할 수 있는 플랜B 제안해줘!" }
            ];
        }

        replies.forEach(reply => {
            const btn = document.createElement('button');
            btn.className = "bg-indigo-950/40 hover:bg-indigo-900/40 border border-indigo-900/40 text-slate-300 hover:text-white px-2.5 py-1 rounded-lg text-[11px] whitespace-nowrap transition-all";
            btn.innerText = reply.text;
            btn.onclick = () => sendMessageToAI(reply.msg);
            wrapper.appendChild(btn);
        });
    }

    function resetChatHistory() {
        chatHistory = [];
        document.getElementById('chat-messages').innerHTML = `
            <div class="flex gap-3 items-start">
                <div class="w-7 h-7 rounded-lg bg-indigo-600 flex items-center justify-center text-white font-bold text-xs flex-shrink-0">Y</div>
                <div class="bg-slate-900 border border-slate-800 rounded-xl px-3.5 py-2.5 max-w-[85%] text-slate-200">
                    반갑습니다! 대화가 완전히 포맷되었습니다. <br>오늘도 성취를 이루고 보상을 등록해 봅시다! 어떤 하루를 보낼 예정이신가요?
                </div>
            </div>
        `;
    }

    // Handle standard inputs
    document.getElementById('chat-send-btn').addEventListener('click', () => sendMessageToAI());
    document.getElementById('chat-input').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') sendMessageToAI();
    });

    // Handle weekday simulations
    document.getElementById('day-selector').addEventListener('change', (e) => {
        selectedDay = parseInt(e.target.value);
        currentModePlanB = false;
        loadRoutine(selectedDay, false);
    });

    window.onload = function() {
        // Find actual day of the week to default properly (Mon-Fri)
        const actualDayNum = new Date().getDay(); // 0: Sun, 1: Mon, etc.
        let defaultSimulatedDay = 1; // Default to Mon if weekend
        if (actualDayNum >= 1 && actualDayNum <= 5) {
            defaultSimulatedDay = actualDayNum;
        }
        
        selectedDay = defaultSimulatedDay;
        document.getElementById('day-selector').value = selectedDay.toString();
        
        // Load initial core elements
        loadRoutine(selectedDay, false);
        renderRewards();
        updatePointsDisplay();
        resetTimerToDefault();
        
        // Add pleasant welcome prompt message implicitly in background
        addSystemNotificationToChat("첫 만남 가이드라인에 맞춘 시작 멘트로 대화해 주세요.");
    }
</script>
