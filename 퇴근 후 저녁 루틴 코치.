- 플랜 B 모드 적용 여부: ${currentModePlanB ? "예 (활성화 상태)" : "아니오 (오리지널 상태)"}
- 사용자 현재 누적 성취 포인트: ${userPoints}p
- 진행중인 미션 목록: ${JSON.stringify(routineTasks)}`;
    }

    function getWeekdayName(num) {
        const days = ["일요일", "월요일", "화요일", "수요일", "목요일", "금요일", "토요일"];
        return days[num] || "미확인";
    }

    function appendChatMessage(sender, text, isAI = false) {
        const chatWindow = document.getElementById('chat-messages');
        const bubble = document.createElement('div');
        bubble.className = `flex gap-3 items-start ${sender === 'user' ? 'justify-end' : ''}`;
        
        const avatar = isAI 
            ? '<div class="w-7 h-7 rounded-lg bg-indigo-600 flex items-center justify-center text-white font-bold text-xs flex-shrink-0">Y</div>'
            : '';
            
        const bubbleStyle = isAI
            ? 'bg-slate-900 border border-slate-800 rounded-xl px-3.5 py-2.5 max-w-[85%] text-slate-200'
            : 'bg-indigo-600 text-white rounded-xl px-3.5 py-2.5 max-w-[85%] font-medium';
            
        bubble.innerHTML = `
            ${avatar}
            <div class="${bubbleStyle}">
                ${text.replace(/\n/g, '<br>')}
            </div>
        `;
        
        chatWindow.appendChild(bubble);
        chatWindow.scrollTop = chatWindow.scrollHeight;
    }

    // Add invisible context metadata into Gemini chat history to keep coach informed of points/missions
    function addSystemNotificationToChat(metaText) {
        chatHistory.push({ role: "user", parts: [{ text: `[시스템 메타 데이터]: ${metaText}` }] });
    }

    async function sendMessageToAI(customMessage = null) {
        const inputEl = document.getElementById('chat-input');
        const text = customMessage || inputEl.value.trim();
        
        if (!text) return;
        
        if (!customMessage) {
            inputEl.value = '';
        }

        // Draw user message
        appendChatMessage('user', text, false);
        chatHistory.push({ role: "user", parts: [{ text: text }] });

        // Show thinking loader
        const loader = document.getElementById('chat-loader');
        loader.classList.remove('hidden');

        try {
            const apiKey = ""; // Left empty as requested to auto-authenticate in Canvas environment
            const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-3-flash-preview:generateContent?key=${apiKey}`;

            const systemInstructionText = getSystemPrompt();

            const payload = {
                contents: chatHistory,
                systemInstruction: {
                    parts: [{ text: systemInstructionText }]
                }
            };

            const response = await fetch(apiUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            if (!response.ok) {
                throw new Error("API call failed");
            }

            const result = await response.json();
            const candidate = result.candidates?.[0];
            
            if (candidate && candidate.content?.parts?.[0]?.text) {
                const generatedResponse = candidate.content.parts[0].text;
                
                // Add AI response to history
                chatHistory.push(candidate.content);
                
                // Render response
                appendChatMessage('coach', generatedResponse, true);
            } else {
                appendChatMessage('coach', "죄송해요, 순간 데이터 흐름이 고르지 못했네요. 다시 한 번 말씀해 주실래요?", true);
            }
        } catch (error) {
            console.error("Gemini API Error", error);
            // Fallback response if offline or error
            const fallbackMsg = "오늘도 정말 고생 많으셨어요! 제가 지금 인터넷 연결 상태가 원활치 않지만, 무엇이든 한 가지 행동을 곧바로 수행하시는 것만으로 큰 의미가 있습니다. 타이머 버튼을 켜고 지금 시작해 보세요! 🔥";
            appendChatMessage('coach', fallbackMsg, true);
        } finally {
            loader.classList.add('hidden');
        }
    }

    function renderQuickReplies() {
