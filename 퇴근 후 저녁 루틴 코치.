    function createNewReward() {
        const name = document.getElementById('reward-name-input').value.trim();
        const points = parseInt(document.getElementById('reward-points-input').value);
        const emoji = document.getElementById('reward-emoji-hidden').value;

        if (!name) {
            showCustomAlert("입력 확인", "보상 상품 이름을 적어주세요!", "fa-exclamation");
            return;
        }
        if (isNaN(points) || points < 50) {
            showCustomAlert("포인트 확인", "포인트는 최소 50p 이상으로 설정해 주세요.", "fa-exclamation");
            return;
        }

        const newId = rewards.length > 0 ? Math.max(...rewards.map(r => r.id)) + 1 : 1;
        rewards.push({
            id: newId,
            name: `${name} ${emoji}`,
            points: points,
            emoji: emoji
        });

        // Reset Inputs
        document.getElementById('reward-name-input').value = '';
        document.getElementById('reward-points-input').value = '500';
        closeAddRewardModal();
        
        saveSystemState();
        renderRewards();
        showCustomAlert("등록 성공!", `보상 상점에 [${name}]이 성공적으로 상륙했습니다. 🏆`, "fa-gift");
    }

    function claimReward(id) {
        const reward = rewards.find(r => r.id === id);
        if (!reward) return;

        if (userPoints < reward.points) {
            showCustomAlert("포인트 부족", "성취 포인트를 더 열심히 적립하세요! 조금만 더 하면 보상에 닿을 수 있어요.", "fa-battery-half");
            return;
        }

        userPoints -= reward.points;
        saveSystemState();
        updatePointsDisplay();
        renderRewards();

        showCustomAlert("환상적인 성취! 🎉", `[${reward.name}] 교환 쿠폰이 성공적으로 발행되었습니다. 오늘 하루도 최고였습니다!`, "fa-award");
        addSystemNotificationToChat(`[코칭 브리핑]: 사용자가 포인트로 [${reward.name}] 보상을 교환했습니다!`);
    }

