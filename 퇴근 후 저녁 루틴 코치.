            <div class="bg-indigo-950/60 border border-indigo-800/40 px-4 py-1.5 rounded-xl flex items-center gap-2">
                <i class="fa-solid fa-crown text-amber-400"></i>
                <div class="text-right">
                    <p class="text-[10px] text-slate-400 uppercase tracking-wider font-semibold">내 성취도 포인트</p>
                    <p class="font-bold text-indigo-300 text-sm" id="header-points">0 <span class="text-xs text-slate-400">p</span></p>
                </div>
            </div>

            <!-- Current Weekday Selector for Simulation -->
            <div class="flex items-center bg-slate-800/60 rounded-xl p-1 border border-slate-700/50">
